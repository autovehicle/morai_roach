# ==========================================
# Python
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Virtual Environments
venv/
env/
.env/
.venv/
env.bak/
venv.bak/

# ==========================================
# PyTorch & Machine Learning
# ==========================================
# Model Checkpoints and weights (Usually large files)
*.pt
*.pth
*.ckpt
*.h5
*.weights

# TensorBoard logs
runs/
logs/

# Datasets (Prevent uploading large data folders)
data/
datasets/
*.csv
*.jsonl

# ==========================================
# Windows Specific
# ==========================================
# Windows image cache
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Folder config file
Desktop.ini

# Recycle Bin
$RECYCLE.BIN/

# ==========================================
# UDP / Batch Script Logs & Outputs
# ==========================================
# Custom logs generated by .bat scripts or UDP tests
*.log
output/
temp/

# ==========================================
# IDEs & Editors
# ==========================================
# Visual Studio Code
.vscode/

# PyCharm / IntelliJ
.idea/
*.iml

# Jupyter Notebook
.ipynb_checkpoints/
